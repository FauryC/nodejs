<section class="grid-container p-4">
    <div class="row card-container"> 
        {{#each gallery_items}}
            <div class="col-12 col-md-6 col-lg-4 card">
                
                <img src="{{item-img}}" alt="{{item-alt}}" />
                <div class="card-content">
                    <h3>{{item-caption}}</h3>
                    <p>{{item-description}}</p>
                </div>
            </div>
        {{/each}}
    </div>
</section>